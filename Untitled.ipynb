    "def count_sum(arr):\n",
    "    total = 0\n",
    "    for num in arr:\n",
    "        total +=num\n",
    "    return total;\n",
    "arr = [1,2,3,4,5]\n",
    "print(\"sum: \",count_sum(arr))\n"
